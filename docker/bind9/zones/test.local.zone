$TTL 86400
@   IN  SOA ns1.test.local. admin.test.local. (
        2024021601  ; Serial
        3600        ; Refresh
        1800        ; Retry
        604800      ; Expire
        86400       ; Minimum TTL
)

@       IN  NS      ns1.test.local.
ns1     IN  A       127.0.0.1
www     IN  A       192.168.1.10
mail    IN  A       192.168.1.20
ftp     IN  A       192.168.1.30
@       IN  MX  10  mail.test.local.
@       IN  TXT     "v=spf1 mx -all"
